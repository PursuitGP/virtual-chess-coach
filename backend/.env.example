# Copy this file to backend/.env for local development.
# Required for completed AI coaching. Never commit a real key.
GEMINI_API_KEY=

# Stable Gemini model used by the synthesis layer.
GEMINI_MODEL=gemini-3.1-flash-lite
# Retries transient Gemini 5xx/high-demand failures within the same request.
GEMINI_PROVIDER_ATTEMPTS=2

# Create a personal token at https://lichess.org/account/oauth/token.
# Leave every permission checkbox unchecked and keep the token server-side.
LICHESS_TOKEN=
LICHESS_EXPLORER_URL=https://explorer.lichess.org

# Optional local override. Docker builds and pins Stockfish 18.
STOCKFISH_PATH=
# Search stops when either the target depth or time cap is reached.
STOCKFISH_DEPTH=24
STOCKFISH_MAX_SECONDS=1.25
STOCKFISH_MULTIPV=1
# Selected tactical positions receive a short alternative-move comparison.
STOCKFISH_CRITICAL_MULTIPV=4
STOCKFISH_CRITICAL_MAX_POSITIONS=4
STOCKFISH_CRITICAL_MAX_SECONDS=0.3
STOCKFISH_THREADS=1
STOCKFISH_HASH_MB=64
STOCKFISH_TOTAL_SECONDS=14

# Optional override for a custom authored study database.
# The default is backend/data/studies.json.
STUDY_DATABASE_PATH=

# Opening-focused public defaults.
MAX_ANALYSIS_PLIES=20
MAX_PGN_BYTES=262144
MAX_REQUEST_BYTES=2097152
LICHESS_TIMEOUT_SECONDS=5
LICHESS_MOVE_LIMIT=10
LICHESS_WORKERS=2
MIN_MASTER_GAMES=20
SOUND_MOVE_LOSS_CP=40
MISTAKE_MOVE_LOSS_CP=100
COMMON_PLAYER_MOVE_PCT=5

# Basic single-instance abuse controls.
ANALYSIS_RATE_LIMIT=20
EXPLAIN_RATE_LIMIT=5
EXPLANATION_CACHE_ITEMS=128

# Runtime settings.
APP_ENV=development
PORT=5050
TRUST_PROXY=false
ENABLE_DEV_ENDPOINTS=false
DISABLE_RATE_LIMITS=false
